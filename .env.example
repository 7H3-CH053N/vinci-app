# Lyra Environment Variables
# Copy to .env and fill in your values

# Gemini API Key (https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Redirect URI: http://localhost:3847/oauth/callback
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# n8n (optional – also configurable in Settings UI)
VITE_N8N_BASE_URL=https://bot.promptrocker.at
VITE_N8N_API_KEY=

# Strom Dashboard API
VITE_STROM_API_URL=https://strom.vibecodes.at/api
